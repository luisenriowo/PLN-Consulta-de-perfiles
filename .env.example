# ============================================================
# PLN-Consulta-de-perfiles — variables de entorno
# Copia este archivo a `.env` y completa los valores reales.
# NUNCA commitees `.env` al repositorio.
# ============================================================


# ── Proveedor LLM activo ──────────────────────────────────────────────────────
#
# UNA SOLA VARIABLE controla el proveedor para TODO el pipeline
# (clasificador de relaciones + generación de timeline).
#
# Opciones: anthropic | openai | groq | gemini
#
# Los defaults de modelo y temperatura están en src/llm/_config.py.
# Solo sobreescribe aquí si quieres valores distintos a los defaults.
#
RELATIONS_LLM_PROVIDER=gemini


# ── API Keys (solo la del proveedor activo es obligatoria) ───────────────────

# Google Gemini — free tier en https://aistudio.google.com/
# Defaults: modelo=gemini-2.5-flash, temp_relaciones=0.0, temp_generacion=0.7
GEMINI_API_KEY=

# Groq — free tier en https://console.groq.com/
# Defaults: modelo=llama-3.3-70b-versatile
# GROQ_API_KEY=gsk_...

# Anthropic
# Defaults: modelo=claude-haiku-4-5
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (o cualquier API compatible: Together, Cerebras, etc.)
# OPENAI_API_KEY=sk-...


# ── Overrides opcionales (dejar vacío usa el default del proveedor) ──────────

# Modelo para clasificación de relaciones (default: ver _config.py)
# RELATIONS_LLM_MODEL=

# Modelo para generación de timeline (default: mismo que clasificación)
# TIMELINE_LLM_MODEL=

# Temperatura clasificación (default: 0.0 — determinista)
# RELATIONS_LLM_TEMPERATURE=0.0

# Temperatura generación (default: 0.7 — variabilidad entre corridas, §5)
# TIMELINE_LLM_TEMPERATURE=0.7


# ── NER (reconocimiento de entidades) ────────────────────────────────────────

# Implementación NER: spacy (rápido) | transformer (más preciso, requiere GPU)
NER_MODEL=spacy

# Modelo spaCy. Requiere: python -m spacy download es_core_news_md
SPACY_NER_MODEL=es_core_news_md

# Modelo HuggingFace (solo si NER_MODEL=transformer)
TRANSFORMER_NER_MODEL=PlanTL-GOB-ES/roberta-base-bne-capiter

# Modelo spaCy para dependency parsing (triples sujeto-verbo-objeto)
SPACY_DEP_MODEL=es_core_news_md


# ── Almacenamiento ────────────────────────────────────────────────────────────

TIMELINE_DATA_DIR=data
WIKIDATA_WORKERS=5


# ── Frontend ──────────────────────────────────────────────────────────────────

TIMELINE_API=http://127.0.0.1:8000
